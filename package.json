{
  "name": "bearcode",
  "version": "1.0.1",
  "description": "BearCode: a desktop agent manager",
  "main": "./out/main/index.js",
  "author": "Zach Rossmiller",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "patch-package && electron-builder install-app-deps",
    "test": "vitest run",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:mac:publish": "electron-vite build && electron-builder --mac --publish always",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.92",
    "@ai-sdk/google": "^3.0.88",
    "@ai-sdk/openai": "^3.0.80",
    "@ai-sdk/openai-compatible": "^2.0.56",
    "@ai-sdk/provider-utils": "^5.0.9",
    "@electron-toolkit/utils": "^4.0.0",
    "@langchain/anthropic": "^1.5.1",
    "@langchain/core": "^1.2.2",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.3",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/ollama": "^1.3.0",
    "@langchain/openai": "^1.5.5",
    "@openrouter/ai-sdk-provider": "^2.10.0",
    "@vscode/ripgrep": "^1.18.0",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.219",
    "better-sqlite3": "^12.11.1",
    "deepagents": "^1.10.7",
    "diff": "^9.0.0",
    "docx": "^9.7.1",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "monaco-editor": "^0.55.1",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.61.1",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.10"
  }
}
